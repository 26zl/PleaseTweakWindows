<Window x:Class="PleaseTweakWindows.Views.Dialogs.ConfigReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Review Import"
        Width="540" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PtwBackgroundBrush}"
        WindowStyle="None"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource PtwBackgroundBrush}"
            BorderBrush="{StaticResource PtwBorderBrush}"
            BorderThickness="1"
            Padding="24"
            CornerRadius="14">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="Review tweaks to apply"
                       FontSize="17" FontWeight="SemiBold"
                       Foreground="{StaticResource PtwTextPrimaryBrush}"
                       Margin="0,0,0,8" />

            <TextBlock DockPanel.Dock="Top"
                       x:Name="SubText"
                       FontSize="13"
                       Foreground="{StaticResource PtwTextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14" />

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Click="OnCancelClick"
                        IsCancel="True"
                        FontSize="13"
                        Padding="14,8"
                        Margin="0,0,10,0" />
                <Button x:Name="ApplyButton"
                        Content="Apply Selected"
                        Style="{StaticResource AccentButton}"
                        Click="OnApplyClick"
                        IsDefault="True"
                        FontSize="13"
                        Padding="14,8" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ItemsHost">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Foreground="{StaticResource PtwTextPrimaryBrush}"
                                      FontSize="13"
                                      Margin="0,5" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
