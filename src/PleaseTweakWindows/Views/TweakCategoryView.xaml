<UserControl x:Class="PleaseTweakWindows.Views.TweakCategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PleaseTweakWindows.ViewModels"
             xmlns:views="clr-namespace:PleaseTweakWindows.Views">

    <Border Style="{StaticResource CategoryCard}" Margin="0,0,0,12">
        <StackPanel>
            <Border Style="{StaticResource CategoryHeader}"
                    MouseLeftButtonDown="OnHeaderPressed"
                    KeyDown="OnHeaderKeyDown"
                    Focusable="True"
                    KeyboardNavigation.TabNavigation="Local"
                    AutomationProperties.Name="{Binding Title}"
                    AutomationProperties.HelpText="Press Enter or Space to expand or collapse this category.">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding IsExpanded, Converter={StaticResource ExpandArrow}}"
                               FontSize="12"
                               Foreground="{StaticResource PtwTextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Width="16" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding Title}"
                               Style="{StaticResource CategoryTitleText}"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="2"
                            Content="Run All"
                            Style="{StaticResource RunFullButton}"
                            Command="{Binding RunFullScriptCommand}"
                            Visibility="{Binding CanRunAll, Converter={StaticResource BoolToVisibility}}"
                            IsEnabled="{Binding IsGloballyRunning, Converter={StaticResource InverseBool}}"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding SubTweaks}"
                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                          Margin="12,4,12,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SubTweakViewModel}">
                        <views:SubTweakView />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
