<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color resources -->
    <Color x:Key="PtwBackground">#0B0B0C</Color>
    <Color x:Key="PtwSurface">#141415</Color>
    <Color x:Key="PtwSurfaceHover">#1C1C1E</Color>
    <Color x:Key="PtwBorder">#2A2A2D</Color>
    <Color x:Key="PtwBorderStrong">#3A3A3F</Color>
    <Color x:Key="PtwAccent">#B91C1C</Color>
    <Color x:Key="PtwAccentHover">#DC2626</Color>
    <Color x:Key="PtwAccentPressed">#7F1D1D</Color>
    <Color x:Key="PtwAccentSubtle">#1A0A0B</Color>
    <Color x:Key="PtwSuccess">#22C55E</Color>
    <Color x:Key="PtwWarning">#D97706</Color>
    <Color x:Key="PtwDanger">#EF4444</Color>
    <Color x:Key="PtwTextPrimary">#EDEDEF</Color>
    <Color x:Key="PtwTextSecondary">#9B9BA0</Color>
    <Color x:Key="PtwTextTertiary">#6B6B70</Color>
    <Color x:Key="PtwLogBackground">#070708</Color>
    <Color x:Key="PtwSubTweakBackground">#111113</Color>
    <Color x:Key="PtwSubTweakHover">#1A1A1D</Color>

    <SolidColorBrush x:Key="PtwBackgroundBrush" Color="{StaticResource PtwBackground}" />
    <SolidColorBrush x:Key="PtwSurfaceBrush" Color="{StaticResource PtwSurface}" />
    <SolidColorBrush x:Key="PtwSurfaceHoverBrush" Color="{StaticResource PtwSurfaceHover}" />
    <SolidColorBrush x:Key="PtwBorderBrush" Color="{StaticResource PtwBorder}" />
    <SolidColorBrush x:Key="PtwBorderStrongBrush" Color="{StaticResource PtwBorderStrong}" />
    <SolidColorBrush x:Key="PtwAccentBrush" Color="{StaticResource PtwAccent}" />
    <SolidColorBrush x:Key="PtwAccentHoverBrush" Color="{StaticResource PtwAccentHover}" />
    <SolidColorBrush x:Key="PtwAccentPressedBrush" Color="{StaticResource PtwAccentPressed}" />
    <SolidColorBrush x:Key="PtwAccentSubtleBrush" Color="{StaticResource PtwAccentSubtle}" />
    <SolidColorBrush x:Key="PtwSuccessBrush" Color="{StaticResource PtwSuccess}" />
    <SolidColorBrush x:Key="PtwWarningBrush" Color="{StaticResource PtwWarning}" />
    <SolidColorBrush x:Key="PtwDangerBrush" Color="{StaticResource PtwDanger}" />
    <SolidColorBrush x:Key="PtwTextPrimaryBrush" Color="{StaticResource PtwTextPrimary}" />
    <SolidColorBrush x:Key="PtwTextSecondaryBrush" Color="{StaticResource PtwTextSecondary}" />
    <SolidColorBrush x:Key="PtwTextTertiaryBrush" Color="{StaticResource PtwTextTertiary}" />
    <SolidColorBrush x:Key="PtwLogBackgroundBrush" Color="{StaticResource PtwLogBackground}" />
    <SolidColorBrush x:Key="PtwSubTweakBrush" Color="{StaticResource PtwSubTweakBackground}" />
    <SolidColorBrush x:Key="PtwSubTweakHoverBrush" Color="{StaticResource PtwSubTweakHover}" />
    <SolidColorBrush x:Key="PtwUpdateBarBrush" Color="#0F1F14" />
    <SolidColorBrush x:Key="PtwUpdateBorderBrush" Color="#1F3F2A" />

    <!-- Global text defaults -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI" />
    </Style>

    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
    </Style>

    <Style x:Key="CategoryTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
    </Style>

    <!-- Base button template -->
    <Style x:Key="PtwButtonBase" TargetType="Button">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent button (primary CTA) -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PtwButtonBase}">
        <Setter Property="Background" Value="{StaticResource PtwAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="16,8" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PtwAccentHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource PtwAccentPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Apply button (compact accent) -->
    <Style x:Key="ApplyButton" TargetType="Button" BasedOn="{StaticResource PtwButtonBase}">
        <Setter Property="Background" Value="{StaticResource PtwAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="MinWidth" Value="68" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PtwAccentHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource PtwAccentPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Revert button (subtle, accent-bordered) -->
    <Style x:Key="RevertButton" TargetType="Button">
        <Setter Property="Background" Value="#191919" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource PtwBorderStrongBrush}" />
        <Setter Property="MinWidth" Value="68" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#242424" />
                <Setter Property="BorderBrush" Value="{StaticResource PtwAccentBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#0F0F0F" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Danger button (destructive CTA) -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PtwButtonBase}">
        <Setter Property="Background" Value="{StaticResource PtwDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="16,8" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F26B6B" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#B91C1C" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Ghost button -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PtwSurfaceHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window close button -->
    <Style x:Key="WindowCloseButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PtwAccentPressedBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Run Full Script button (outlined accent) -->
    <Style x:Key="RunFullButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PtwAccentHoverBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource PtwAccentBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PtwAccentSubtleBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Category card -->
    <Style x:Key="CategoryCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PtwSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PtwBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <!-- Category header -->
    <Style x:Key="CategoryHeader" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="14,14,0,0" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PtwSurfaceHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Sub-tweak item -->
    <Style x:Key="SubTweakItem" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PtwSubTweakBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,2" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PtwSubTweakHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Search textbox -->
    <Style x:Key="SearchTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#101012" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource PtwAccentHoverBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource PtwAccentPressedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PtwBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PtwAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Log output textbox -->
    <Style x:Key="LogAreaTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource PtwLogBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource PtwTextPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource PtwAccentPressedBrush}" />
        <Setter Property="FontFamily" Value="Cascadia Mono, Cascadia Code, Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="BorderBrush" Value="{StaticResource PtwBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalScrollBarVisibility="Auto" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Update banner -->
    <Style x:Key="UpdateBannerBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PtwUpdateBarBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PtwUpdateBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <!-- Indeterminate spinner -->
    <Style x:Key="PtwSpinner" TargetType="ProgressBar">
        <Setter Property="IsIndeterminate" Value="True" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="3" />
        <Setter Property="Foreground" Value="{StaticResource PtwAccentHoverBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Tooltip -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource PtwSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PtwTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PtwBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ContentPresenter Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
