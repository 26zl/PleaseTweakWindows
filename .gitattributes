# Default: auto-detect text, normalize to LF in the repo.
* text=auto eol=lf

# Windows-only tooling expects CRLF.
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.sln    text eol=crlf

# Source / config — LF for clean diffs across machines.
*.cs        text eol=lf
*.csproj    text eol=lf
*.xaml      text eol=lf
*.axaml     text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.manifest  text eol=lf
*.cfg       text eol=lf
*.ps1       text eol=lf
*.psm1      text eol=lf
*.psd1      text eol=lf

# .reg files ship in mixed encodings (some UTF-16 LE + BOM, some ASCII/CRLF, none with
# LF) — treat as binary so git never normalizes them. regedit refuses a normalized
# (LF-converted) .reg file, and normalizing UTF-16 would corrupt it outright.
*.reg    binary

# Images / icons.
*.ico    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary

# Keep registry payloads out of GitHub's language stats.
*.reg                    linguist-generated
scripts/**/regs/**       linguist-generated
scripts/**/reg/**        linguist-generated
